# Start Google OAuth flow - returns redirect URL
flow "google_login" {
  from {
    connector = "api"
    operation = "GET /auth/google"
  }

  to {
    connector = "google_auth"
    operation = "authorize"
  }
}

# Handle Google callback - exchange code for user info
flow "google_callback" {
  from {
    connector = "api"
    operation = "GET /auth/google/callback"
  }

  step "auth" {
    connector = "google_auth"
    operation = "callback"
    params = {
      code  = "input.query.code"
      state = "input.query.state"
    }
  }

  transform {
    email       = "step.auth.email"
    name        = "step.auth.name"
    picture     = "step.auth.picture"
    provider    = "'google'"
    provider_id = "step.auth.provider_id"
  }

  to {
    connector = "db"
    target    = "users"
  }
}

# Start GitHub OAuth flow
flow "github_login" {
  from {
    connector = "api"
    operation = "GET /auth/github"
  }

  to {
    connector = "github_auth"
    operation = "authorize"
  }
}

# Handle GitHub callback
flow "github_callback" {
  from {
    connector = "api"
    operation = "GET /auth/github/callback"
  }

  step "auth" {
    connector = "github_auth"
    operation = "callback"
    params = {
      code  = "input.query.code"
      state = "input.query.state"
    }
  }

  transform {
    email       = "step.auth.email"
    name        = "step.auth.name"
    picture     = "step.auth.picture"
    provider    = "'github'"
    provider_id = "step.auth.provider_id"
  }

  to {
    connector = "db"
    target    = "users"
  }
}
